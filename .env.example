# NetGuard — example environment.
# Copy to `.env` and fill REAL values there. `.env` is gitignored; never commit secrets.
# Every service reads its config from env vars (pydantic-settings). No value is hardcoded in code.

# ── inference ────────────────────────────────────────────────────────────────
INFERENCE_MODEL_DIR=/models
# Comma/JSON list; empty = same-origin only (behind nginx). e.g. ["http://localhost:5173"]
INFERENCE_CORS_ORIGINS=[]

# ── collector ────────────────────────────────────────────────────────────────
COLLECTOR_INFERENCE_URL=http://inference:8000
COLLECTOR_REDIS_URL=redis://redis:6379/0
COLLECTOR_INTERVAL_SECONDS=2
COLLECTOR_REAL_TRAFFIC_SAMPLE=4000

# ── backend-api (the only public surface) ────────────────────────────────────
API_REDIS_URL=redis://redis:6379/0
API_INFERENCE_URL=http://inference:8000
API_COLLECTOR_URL=http://collector:8000
API_AIOPS_URL=http://aiops-engine:8000
API_PROMETHEUS_URL=
API_LOKI_URL=
API_CORS_ORIGINS=[]

# ── aiops-engine ─────────────────────────────────────────────────────────────
# REQUIRED secret for AIOps diagnosis — set in your real .env or k8s Secret, never commit it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Empty = in-memory fallback (local dev). In cluster: postgresql://user:pass@host:5432/aiops
AIOPS_DB_URL=
# Read directly by the lifted aiops tools (unprefixed). Empty = mock data (local dev).
PROMETHEUS_URL=
LOKI_URL=

# ── local compose only ───────────────────────────────────────────────────────
# Dev default is "aiops"; override for anything shared.
POSTGRES_PASSWORD=aiops
